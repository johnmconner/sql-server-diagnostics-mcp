{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SQL TShooter Desktop",
  "version": "0.1.0",
  "identifier": "com.sqltshooter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SQL TShooter",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Target-aware Codex desktop shell for SQL TShooter",
    "longDescription": "A structured desktop app that binds Codex sessions to specific SQL Server targets via SQL TShooter MCP."
  }
}
